#!/usr/bin/env bash
# Copyright 2025 Andrey Brusnik <dev@shdwchn.io>

set -Eeuo pipefail

help() {
  cat <<EOF
Usage:
  $(basename "${BASH_SOURCE[0]}") [-h] [-v] DEVICE USB_SPEED

Limit USB drive write-back buffer size based on USB version/speed.

Script Options:
  -h, --help      Show this message
  -v, --verbose   Enable verbose output
EOF

  exit "${1-0}" # return code 0 by default
}

say() {
  echo -e "${1-}" >&2
}

err() {
  say "error: ${1}"
}

abort() {
  err "$1"
  exit "${2-1}" # return code 1 by default
}

# shellcheck disable=SC2310
parse_args() {
  while true; do
    case "${1-}" in
    -h | --help) help ;;
    -v | --verbose) set -x ;;
    -?*) abort "Unknown option $1" ;;
    *) break ;;
    esac

    shift
  done

  args=("$@")

  [[ ${#args[@]} -ne 2 ]] && err "Must specify DEVICE and USB_SPEED\n" && help 1

  device=${args[0]}
  speed=${args[1]}

  return 0
}

parse_args "$@"

say "Device: ${device}"
say "Speed: ${speed}"

LANG=C # fixes printf locale-specific errors

if command -v hdparm &>/dev/null; then
  hdparm -W 0 "/dev/${device}" &>/dev/null || true
fi

# https://docs.kernel.org/admin-guide/abi-testing.html#abi-sys-class-bdi-bdi-strict-limit
# Turning strictlimit on has no visible effect if max_ratio is equal to 100%
echo 99 >"/sys/block/${device}/bdi/max_ratio"
echo 1 >"/sys/block/${device}/bdi/strict_limit"

# Use buffer size which will flush in ~0.1s
max_bytes=$(bc <<<"( (${speed} / 8) * 0.1) * 1024 * 1024")
max_bytes=$(printf '%.0f' "${max_bytes}")
echo "${max_bytes}" >"/sys/block/${device}/bdi/max_bytes"
